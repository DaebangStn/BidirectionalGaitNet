{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Install Script",
			"type": "shell",
			"command": "./install.sh",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [],
			"options": {
				"env": {
				}
			}
		},
		{
			"label": "Configure CMake",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--preset release",
				".."
			],
			"problemMatcher": [],
			"dependsOn": [
			]
		},
		{
			"label": "Configure CMake (Debug)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--preset debug",
				".."
			],
			"problemMatcher": [],
			"dependsOn": [
			]
		},
		{
			"label": "Build",
			"type": "shell",
			"command": "ninja",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"options": {
				"cwd": "${workspaceFolder}/release"
			},
			"problemMatcher": [],
			"dependsOn": "Configure CMake"
		},
		{
			"label": "Build (Debug)",
			"type": "shell",
			"command": "ninja",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"options": {
				"cwd": "${workspaceFolder}/debug"
			},
			"problemMatcher": [],
			"dependsOn": "Configure CMake (Debug)"
		},
		{
			"label": "Clean",
			"type": "shell",
			"command": "rm",
			"args": [
				"-rf",
				"${workspaceFolder}/release",
				"${workspaceFolder}/debug",
				"${workspaceFolder}/server"
			],
			"problemMatcher": [],
			"group": {
				"kind": "none",
				"isDefault": true
			}	
		},
		{
			"label": "Run Viewer",
			"type": "process",
			"command": "${workspaceFolder}/release/viewer/viewer",
			"args": [
				"${workspaceFolder}/data/env_merge.xml"
			],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/release"
			},
			"dependsOn": "Activate Venv"
		},
		{
			"label": "Activate Venv",
			"type": "shell",
			"command": "source ${workspaceFolder}/.venv/bin/activate"
		}
	]
  }
  