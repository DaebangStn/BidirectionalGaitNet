{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release",
      "hidden": false,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "Python_EXECUTABLE": "/home/geon/BidirectionalGaitNet/.venv/bin/python3.6",
        "PYTHON_INCLUDE_DIR": "/usr/include/python3.6m",
        "SERVER_BUILD": false
      },
      "environment": {
        "ENVDIR": "$env{HOME}/pkgenv"
      }
    },
    {
      "name": "debug",
      "inherits": "release",
      "binaryDir": "${sourceDir}/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "server",
      "inherits": "release",
      "hidden": false,
      "binaryDir": "${sourceDir}/server",
      "cacheVariables": {
        "SERVER_BUILD": true,
        "Python_EXECUTABLE": "/home/geon/.conda/envs/gait/bin/python3.6"
      },
      "environment": {
        "CC": "/opt/ohpc/pub/compiler/gcc/11.5.0/bin/gcc",
        "CXX": "/opt/ohpc/pub/compiler/gcc/11.5.0/bin/g++"
      }
    }
  ]
}