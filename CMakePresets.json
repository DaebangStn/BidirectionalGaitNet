{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release",
      "hidden": false,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PYTHON_VERSION": "3.6",
        "SERVER_BUILD": false
      },
      "environment": {
        "ENVDIR": "$env{HOME}/pkgenv"
      }
    },
    {
      "name": "debug",
      "inherits": "release",
      "binaryDir": "${sourceDir}/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "server",
      "inherits": "release",
      "hidden": false,
      "binaryDir": "${sourceDir}/server",
      "cacheVariables": {
        "SERVER_BUILD": true
      }
    }
  ]
}